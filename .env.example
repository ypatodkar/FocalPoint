# ── Chat model (Gemini Flash — fast, runs every message) ──
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── RSI meta-agent (Antigravity — runs once per session end) ──
ANTIGRAVITY_MODEL=antigravity-preview-05-2026
RSI_FALLBACK_MODEL=gemini-2.0-pro

# ── MongoDB Atlas ──
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_DB_NAME=focalpoint

# ── DigitalOcean GenAI (LLM fallback if Gemini credits run out) ──
DO_GENAI_API_KEY=your_do_key_here
DO_GENAI_ENDPOINT=your_do_endpoint_here

# ── MiniMax (second fallback) ──
MINIMAX_API_KEY=your_minimax_key_here
