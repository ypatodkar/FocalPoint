# Gemini
GEMINI_API_KEY=your_gemini_key_here

# MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_DB_NAME=focalpoint

# DigitalOcean GenAI (fallback LLM)
DO_GENAI_API_KEY=your_do_key_here
DO_GENAI_ENDPOINT=your_do_endpoint_here

# MiniMax (second fallback)
MINIMAX_API_KEY=your_minimax_key_here

# App — switch between: gemini / digitalocean / minimax
ACTIVE_LLM=gemini
