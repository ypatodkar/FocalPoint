{
  "name": "focalpoint",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n backend,frontend -c blue,green \"npm run backend:dev\" \"npm run frontend:dev\"",
    "backend:dev": "cd backend && python3 -m uvicorn main:app --reload --port 8000",
    "frontend:dev": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "preview": "cd frontend && npm run preview"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
